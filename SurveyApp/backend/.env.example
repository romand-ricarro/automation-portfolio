# OpenAI
OPENAI_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
DATABASE_URL=postgresql://user:password@host:port/dbname

# Google Sheets API
GOOGLE_SHEETS_CREDENTIALS=
GOOGLE_SHEETS_SPREADSHEET_ID=

# Flask
FLASK_SECRET_KEY=dev-secret-key
FLASK_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Sentry (Error Tracking) - Mission Alpha
# Get your DSN from https://sentry.io
SENTRY_DSN=

# Mission Bravo: Analysis Caching
# Number of days to cache AI analysis results (default: 7)
ANALYSIS_CACHE_TTL_DAYS=7

# Mission Charlie: Email Notifications
# Get your API key from https://resend.com
RESEND_API_KEY=
FROM_EMAIL=InsightPulse <notifications@yourdomain.com>
APP_URL=http://localhost:5173
